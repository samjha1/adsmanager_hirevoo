APP_NAME="Ads Manager"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/themesdesign.in/leadsmanager/public

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hirevo
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_CONNECTION=mysql
SESSION_LIFETIME=120
SESSION_COOKIE=leadsmanager_session

CACHE_DRIVER=file
QUEUE_CONNECTION=sync

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@leadsmanager.test"
MAIL_FROM_NAME="${APP_NAME}"
